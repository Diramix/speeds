{
    "name": "speeds",
    "author": "diram1x",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "ymtm dev",
        "build": "ymtm build",
        "build:nextmusic": "ymtm build nextmusic",
        "build:web": "ymtm build web"
    },
    "build": {
        "src": "src",
        "targets": [
            "nextmusic",
            "web"
        ]
    },
    "nextmusic": {
        "tarGz": {
            "artifactName": "${addon.name}_${addon.version}_nm.tar.gz"
        }
    },
    "web": {
        "icon": "https://github.com/Diramix/speeds/blob/main/src/assets/branding/icon.webp?raw=true",
        "onefile": {
            "artifactName": "${addon.name}_${addon.version}_web.user.js"
        }
    },
    "devDependencies": {
        "@diram1x/ymtm": "^3.1.1",
        "typescript": "^6.0.2"
    }
}
